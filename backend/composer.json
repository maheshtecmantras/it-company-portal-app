{
  "name": "maheshtecmantras/it-company-portal-backend",
  "description": "Laravel API powering the IT company portal",
  "type": "project",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.3",
    "laravel/sanctum": "^3.3"
  },
  "require-dev": {
    "fakerphp/faker": "^1.21",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
